{
    "manifest_version":3,
    "name": "twitter bot",
    "version": "1.0",
    "action":{
        "default_popup": "first.html",
        "default_title": "Twitter Bot Detection"
    },
    
    "background": {
        "service_worker": "background.js"
    },

    "permissions": ["storage","activeTab"],

    "content_scripts": [
        {
            "matches": ["https://x.com/*"],
            "exclude_matches": [
                "https://x.com/home*",
                "https://x.com/explore*",
                "https://x.com/notifications*",
                "https://x.com/messages*",
                "https://x.com/i/*",
                "https://x.com/settings/*"
            ],
            "js": ["content.js"]
        }
    ]

}