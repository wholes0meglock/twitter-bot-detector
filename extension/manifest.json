{
    "manifest_version":3,
    "name": "twitter bot",
    "version": "1.0",
    "action":{
        "default_popup": "first.html",
        "default_title": "Twitter Bot Detection"
    },
    
    "background": {
        "service_worker": "background.js"
    },

    "permissions": ["storage","activeTab"],

    "content_scripts": [
        {
            "matches": ["*://*.x.com/*"],
            "js": ["content.js"]
        }
    ]

}